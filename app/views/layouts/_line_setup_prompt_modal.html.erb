<%
  social_account = Current.business_owner.social_account
  if social_account.nil? || !social_account.line_settings_finished?
    line_setup_status = "setup_needed"
  elsif !social_account.line_settings_verified?
    line_setup_status = "verification_needed"
  else
    line_setup_status = "complete"
  end
%>

<% unless line_setup_status == "complete" %>
  <%
    verification_url = if line_setup_status == "verification_needed" && Current.business_owner.social_user.present?
      lines_verification_path(
        encrypted_social_service_user_id: MessageEncryptor.encrypt(Current.business_owner.social_user.social_service_user_id),
        encrypted_business_owner_id: MessageEncryptor.encrypt(Current.business_owner.id)
      )
    end
  %>

  <div data-controller="line-setup-prompt"
       data-line-setup-prompt-status="<%= line_setup_status %>"
       style="display:none;">

    <div class="modal fade" id="lineSetupPromptModal" tabindex="-1" role="dialog">
      <div class="modal-dialog line-setup-prompt-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <% if line_setup_status == "setup_needed" %>
              <h4 class="modal-title">LINE連携設定が必要です</h4>
            <% else %>
              <h4 class="modal-title">LINE連携の動作確認が必要です</h4>
            <% end %>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
          <div class="modal-body">
            <% if line_setup_status == "setup_needed" %>
              <p>LINE連携設定をすることで、Toruyaを通じてあなたの公式LINEから自動送信できるようになります。</p>
              <div class="line-setup-prompt-actions">
                <a href="https://toruya.com/help/line_sync/" target="_blank" rel="noopener" class="BTNtarco">LINE連携の設定方法を確認する</a>
              </div>
            <% else %>
              <p>動作確認が完了するまで、LINEの自動送信に失敗する可能性があります。</p>
              <div class="line-setup-prompt-actions">
                <a href="<%= verification_url %>" class="BTNyellow">今すぐ動作確認する</a>
                <a href="https://toruya.com/help/verify-line-linkage/" target="_blank" rel="noopener" class="BTNtarco">動作テスト方法を確認する</a>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
