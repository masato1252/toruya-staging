<div class="modal fade" id="shopSetupPromptModal" tabindex="-1" role="dialog">
  <div class="modal-dialog shop-setup-prompt-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title"><%= t("settings.shop.setup_prompt.title") %></h4>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <p><%= t("settings.shop.setup_prompt.body") %></p>
      </div>
      <div class="modal-footer centerize">
        <%= link_to t("settings.shop.setup_prompt.confirm_button"),
                    edit_settings_user_shop_path(super_user, setup_pending_shop),
                    class: "BTNtarco" %>
      </div>
    </div>
  </div>
</div>

<div data-controller="shop-setup-prompt"
     data-shop-setup-prompt-user-id="<%= super_user.id %>"
     data-shop-setup-prompt-enabled="<%= setup_pending_shop.present? %>">
</div>
