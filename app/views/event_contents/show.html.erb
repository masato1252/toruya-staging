<%= react_component("event_contents/show", {
  props: {
    event_content: @event_content_hash,
    event_slug: @event.slug,
    event_title: @event.title,
    start_usage_url: start_usage_event_event_content_path(event_slug: @event.slug, id: @event_content.id, format: "json"),
    upsell_consultation_url: upsell_consultation_event_event_content_path(event_slug: @event.slug, id: @event_content.id, format: "json"),
    monitor_apply_url: monitor_apply_event_event_content_path(event_slug: @event.slug, id: @event_content.id, format: "json"),
    track_activity_url: track_activity_event_event_content_path(event_slug: @event.slug, id: @event_content.id, format: "json"),
    back_url: event_path(slug: @event.slug),
    line_login_url: @current_event_line_user ? nil : event_auth_line_path(event_slug: @event.slug, return_to: request.path),
    add_friend_url: Rails.application.secrets.dig(:ja, :toruya_official_line_add_friend_url),
    current_event_line_user_id: @current_event_line_user&.id,
    event_ended: @event.ended?,
    event_logo_image_url: @event.logo_image.attached? ? rails_blob_path(@event.logo_image, only_path: true) : nil
  }
}, { camelize_props: false }) %>
