<%= form_with(model: [:admin, doc], local: true, html: { class: "admin-event-form", multipart: true }) do |f| %>
  <div class="admin-form-section">
    <div class="admin-form-section-title">資料情報</div>

    <div class="admin-form-group">
      <label class="admin-form-label">公開状態</label>
      <div class="admin-form-input">
        <%= f.select :status, [["公開中", "published"], ["非公開", "unpublished"]], {}, class: "form-control" %>
      </div>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        タイトル<span class="required-mark">*</span>
      </label>
      <div class="admin-form-input">
        <%= f.text_field :title, class: "form-control #{'field-error-border' if doc.errors[:title].any?}", placeholder: "資料タイトル" %>
        <% if doc.errors[:title].any? %>
          <span class="admin-form-error"><%= doc.errors.full_messages_for(:title).join(", ") %></span>
        <% end %>
      </div>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">サムネイル画像</label>
      <div class="admin-form-input">
        <% if doc.thumbnail.attached? %>
          <div style="margin-bottom: 8px;">
            <%= image_tag doc.thumbnail, style: "max-width: 320px; max-height: 180px; border-radius: 8px; object-fit: cover;" %>
          </div>
        <% end %>
        <%= f.file_field :thumbnail, accept: "image/*", class: "form-control" %>
      </div>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">説明文</label>
      <div class="admin-form-input">
        <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "資料の説明（任意）" %>
      </div>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        資料URL<span class="required-mark">*</span>
      </label>
      <div class="admin-form-input">
        <%= f.url_field :document_url, class: "form-control #{'field-error-border' if doc.errors[:document_url].any?}", placeholder: "https://..." %>
        <% if doc.errors[:document_url].any? %>
          <span class="admin-form-error"><%= doc.errors.full_messages_for(:document_url).join(", ") %></span>
        <% end %>
      </div>
    </div>

    <% if doc.persisted? %>
      <div class="admin-form-group">
        <label class="admin-form-label">動線URL（自動発行）</label>
        <div class="admin-form-input">
          <code><%= doc_url(slug: doc.slug) %></code>
        </div>
      </div>
    <% end %>
  </div>

  <div class="admin-form-actions">
    <%= f.submit doc.persisted? ? "更新する" : "作成する", class: "btn btn-tarco" %>
    <%= link_to "キャンセル", doc.persisted? ? admin_doc_path(doc) : admin_docs_path, class: "btn btn-gray" %>
  </div>
<% end %>
