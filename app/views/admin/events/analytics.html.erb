<%= render "admin/features" %>

<div class="admin-event-detail">
  <div class="admin-detail-header">
    <h2><%= @event.title %> - アクセス解析</h2>
    <div class="admin-detail-actions">
      <%= link_to "イベント詳細に戻る", admin_event_path(@event), class: "btn btn-gray" %>
    </div>
  </div>

  <div class="admin-detail-section">
    <div class="admin-form-section-title">アクティビティ全体集計</div>
    <div class="admin-analytics-grid">
      <div class="admin-analytics-card">
        <div class="analytics-value text-indigo"><%= @activity_counts["seminar_view"] || 0 %></div>
        <div class="analytics-label">セミナー講演閲覧</div>
      </div>
      <div class="admin-analytics-card">
        <div class="analytics-value text-blue"><%= @activity_counts["material_download"] || 0 %></div>
        <div class="analytics-label">資料ダウンロード</div>
      </div>
      <div class="admin-analytics-card">
        <div class="analytics-value text-tarco"><%= @activity_counts["online_service_click"] || 0 %></div>
        <div class="analytics-label">オンラインサービス遷移</div>
      </div>
      <div class="admin-analytics-card">
        <div class="analytics-value text-orange"><%= @activity_counts["upsell_click"] || 0 %></div>
        <div class="analytics-label">アップセルクリック</div>
      </div>
    </div>
  </div>

  <% @event_contents.each do |content| %>
    <div class="admin-detail-section">
      <div class="admin-form-section-title">
        <%= content.title %>
        <span class="admin-badge admin-badge-info" style="margin-left: 8px;"><%= content.seminar_content_type? ? "セミナー講演" : "展示ブース" %></span>
      </div>
      <div class="admin-analytics-grid">
        <div class="admin-analytics-card">
          <div class="analytics-value text-tarco">
            <%= Ahoy::Event.where(name: "event_content_view").where("properties->>'event_content_id' = ?", content.id.to_s).count %>
          </div>
          <div class="analytics-label">PV</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-blue">
            <%= Ahoy::Event.where(name: "event_content_view").where("properties->>'event_content_id' = ?", content.id.to_s).count(Arel.sql("DISTINCT properties->>'event_line_user_id'")) %>
          </div>
          <div class="analytics-label">来場者(UU)</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-green"><%= content.usage_count %></div>
          <div class="analytics-label">リード</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-orange"><%= content.event_upsell_consultations.count %></div>
          <div class="analytics-label">相談予約</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-purple"><%= content.event_monitor_applications.count %></div>
          <div class="analytics-label">モニター応募</div>
        </div>
      </div>

      <div style="margin-top: 12px;">
        <div class="admin-analytics-grid">
          <div class="admin-analytics-card">
            <div class="analytics-value text-indigo"><%= @content_activity_counts[[content.id, "seminar_view"]] || 0 %></div>
            <div class="analytics-label">動画閲覧</div>
          </div>
          <div class="admin-analytics-card">
            <div class="analytics-value text-blue"><%= @content_activity_counts[[content.id, "material_download"]] || 0 %></div>
            <div class="analytics-label">資料DL</div>
          </div>
          <div class="admin-analytics-card">
            <div class="analytics-value text-tarco"><%= @content_activity_counts[[content.id, "online_service_click"]] || 0 %></div>
            <div class="analytics-label">サービス遷移</div>
          </div>
          <div class="admin-analytics-card">
            <div class="analytics-value text-orange"><%= @content_activity_counts[[content.id, "upsell_click"]] || 0 %></div>
            <div class="analytics-label">アップセル</div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @activity_logs.any? %>
    <div class="admin-detail-section">
      <div class="admin-form-section-title">アクティビティ履歴（直近100件）</div>
      <table class="admin-participant-table">
        <thead>
          <tr>
            <th>日時</th>
            <th>参加者</th>
            <th>コンテンツ</th>
            <th>アクション</th>
          </tr>
        </thead>
        <tbody>
          <% @activity_logs.limit(100).each do |log| %>
            <tr>
              <td><%= l(log.created_at, format: :short) %></td>
              <td><%= log.event_line_user&.name.presence || log.event_line_user&.display_name || "-" %></td>
              <td><%= log.event_content&.title || "-" %></td>
              <td>
                <% case log.activity_type %>
                <% when "seminar_view" %>
                  <span class="admin-badge admin-badge-info">動画閲覧</span>
                <% when "material_download" %>
                  <span class="admin-badge admin-badge-success">資料DL</span>
                <% when "online_service_click" %>
                  <span class="admin-badge" style="background: #e0f2fe; color: #0369a1;">サービス遷移</span>
                <% when "upsell_click" %>
                  <span class="admin-badge" style="background: #fff7ed; color: #c2410c;">アップセル</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
