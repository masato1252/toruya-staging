<%= render "admin/features" %>

<div class="admin-event-detail">
  <div class="admin-detail-header">
    <h2><%= @event.title %> - アクセス解析</h2>
    <div class="admin-detail-actions">
      <%= link_to "イベント詳細に戻る", admin_event_path(@event), class: "btn btn-gray" %>
    </div>
  </div>

  <div class="admin-detail-section">
    <div class="admin-form-section-title">アクセス数（全体）</div>
    <div class="admin-analytics-grid">
      <% [["全体", @overall_access_counts[:total], "text-tarco"], ["参加登録前", @overall_access_counts[:before_registration], "text-blue"], ["参加登録後", @overall_access_counts[:after_registration], "text-green"]].each do |label, counts, color_class| %>
        <div class="admin-analytics-card">
          <div class="analytics-value <%= color_class %>"><%= counts[:pv] %> / <%= counts[:uu] %></div>
          <div class="analytics-label"><%= label %> PV / UU</div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="admin-detail-section">
    <div class="admin-form-section-title">アクティビティ全体集計</div>
    <div class="admin-analytics-grid">
      <div class="admin-analytics-card">
        <div class="analytics-value text-indigo"><%= @seminar_activity_counts["seminar_view"] || 0 %></div>
        <div class="analytics-label">セミナー講演 動画閲覧</div>
      </div>
      <div class="admin-analytics-card">
        <div class="analytics-value text-blue"><%= @booth_activity_counts["material_download"] || 0 %></div>
        <div class="analytics-label">展示ブース 資料DL</div>
      </div>
      <div class="admin-analytics-card">
        <div class="analytics-value text-tarco"><%= @booth_activity_counts["online_service_click"] || 0 %></div>
        <div class="analytics-label">展示ブース サービス遷移</div>
      </div>
    </div>
  </div>

  <% @event_contents.each do |content| %>
    <% access_counts = @content_access_counts[content.id] %>
    <div class="admin-detail-section">
      <div class="admin-form-section-title">
        <%= content.title %>
        <span class="admin-badge admin-badge-info" style="margin-left: 8px;"><%= content.seminar_content_type? ? "セミナー講演" : "展示ブース" %></span>
      </div>
      <div class="admin-analytics-grid">
        <div class="admin-analytics-card">
          <div class="analytics-value text-tarco"><%= access_counts[:total][:pv] %> / <%= access_counts[:total][:uu] %></div>
          <div class="analytics-label">全体 PV / UU</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-blue"><%= access_counts[:before_registration][:pv] %> / <%= access_counts[:before_registration][:uu] %></div>
          <div class="analytics-label">参加登録前 PV / UU</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-green"><%= access_counts[:after_registration][:pv] %> / <%= access_counts[:after_registration][:uu] %></div>
          <div class="analytics-label">参加登録後 PV / UU</div>
        </div>
        <% if content.booth_content_type? %>
          <div class="admin-analytics-card">
            <div class="analytics-value text-teal"><%= content.analytics_registration_count %></div>
            <div class="analytics-label">参加登録</div>
          </div>
        <% end %>
        <div class="admin-analytics-card">
          <div class="analytics-value text-green"><%= content.analytics_usage_count %></div>
          <div class="analytics-label">リード</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-orange"><%= content.analytics_upsell_consultations_count %></div>
          <div class="analytics-label">相談予約</div>
        </div>
        <div class="admin-analytics-card">
          <div class="analytics-value text-purple"><%= content.analytics_monitor_applications_count %></div>
          <div class="analytics-label">モニター応募</div>
        </div>
      </div>

      <div style="margin-top: 12px;">
        <div class="admin-analytics-grid">
          <% if content.seminar_content_type? %>
            <div class="admin-analytics-card">
              <div class="analytics-value text-indigo"><%= @content_activity_counts[[content.id, "seminar_view"]] || 0 %></div>
              <div class="analytics-label">動画閲覧</div>
            </div>
          <% else %>
            <div class="admin-analytics-card">
              <div class="analytics-value text-blue"><%= @content_activity_counts[[content.id, "material_download"]] || 0 %></div>
              <div class="analytics-label">資料DL</div>
            </div>
            <div class="admin-analytics-card">
              <div class="analytics-value text-tarco"><%= @content_activity_counts[[content.id, "online_service_click"]] || 0 %></div>
              <div class="analytics-label">サービス遷移</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @activity_logs.any? %>
    <div class="admin-detail-section">
      <div class="admin-form-section-title">アクティビティ履歴（直近100件）</div>
      <table class="admin-participant-table">
        <thead>
          <tr>
            <th>日時</th>
            <th>参加者</th>
            <th>コンテンツ</th>
            <th>アクション</th>
          </tr>
        </thead>
        <tbody>
          <% @activity_logs.limit(100).each do |log| %>
            <tr>
              <td><%= l(log.created_at, format: :short) %></td>
              <td><%= log.event_line_user&.name.presence || log.event_line_user&.display_name || "-" %></td>
              <td><%= log.event_content&.title || "-" %></td>
              <td>
                <% case log.activity_type %>
                <% when "seminar_view" %>
                  <span class="admin-badge admin-badge-info">動画閲覧</span>
                <% when "material_download" %>
                  <span class="admin-badge admin-badge-success">資料DL</span>
                <% when "online_service_click" %>
                  <span class="admin-badge" style="background: #e0f2fe; color: #0369a1;">サービス遷移</span>
                <% when "upsell_click" %>
                  <span class="admin-badge" style="background: #fff7ed; color: #c2410c;">アップセル</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
