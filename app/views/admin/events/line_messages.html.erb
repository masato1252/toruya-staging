<%= render "admin/features" %>

<div class="admin-event-form">
  <div class="admin-detail-header">
    <h2><%= @event.title %> - LINEメッセージ設定</h2>
    <div class="admin-detail-actions">
      <%= link_to "イベント詳細に戻る", admin_event_path(@event), class: "btn btn-gray" %>
    </div>
  </div>

  <% active_line_message_tab = (@editing_event_line_message_broadcast || @event_line_message_broadcast&.errors&.any?) ? "broadcast" : "trigger" %>

  <style>
    .admin-line-message-tabs {
      display: flex;
      gap: 8px;
      border-bottom: 1px solid #e5e7eb;
      margin-bottom: 20px;
    }

    .admin-line-message-tab {
      appearance: none;
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-bottom: 0;
      border-radius: 8px 8px 0 0;
      color: #64748b;
      cursor: pointer;
      font-weight: 700;
      padding: 12px 18px;
    }

    .admin-line-message-tab.is-active {
      background: #fff;
      color: #111827;
      position: relative;
      top: 1px;
    }

    .admin-line-message-panel[hidden] {
      display: none;
    }

    .admin-form-input.is-disabled {
      opacity: 0.55;
    }

    .admin-form-input.is-disabled input {
      background: #f3f4f6;
      cursor: not-allowed;
    }
  </style>

  <div class="admin-line-message-tabs" role="tablist" aria-label="LINEメッセージ設定">
    <button type="button" class="admin-line-message-tab <%= 'is-active' if active_line_message_tab == 'trigger' %>" data-line-message-tab="trigger" role="tab" aria-selected="<%= active_line_message_tab == 'trigger' %>">
      参加登録完了時のLINEメッセージ
    </button>
    <button type="button" class="admin-line-message-tab <%= 'is-active' if active_line_message_tab == 'broadcast' %>" data-line-message-tab="broadcast" role="tab" aria-selected="<%= active_line_message_tab == 'broadcast' %>">
      参加登録済みユーザーへの一括配信
    </button>
  </div>

  <div class="admin-line-message-panel" data-line-message-panel="trigger" <%= "hidden" unless active_line_message_tab == "trigger" %>>
    <%= form_with(model: [:admin, @event], url: line_messages_admin_event_path(@event), method: :patch, local: true) do |f| %>
      <div class="admin-form-section">
      <div class="admin-form-section-title">参加登録完了時のLINEメッセージ</div>

      <div class="admin-form-group">
        <span class="admin-form-help" style="font-size: 11px;">
          LINEログイン完了時（プロフィール入力前）に、送信期間に一致する有効なメッセージを初回だけ送信します。終了日時が空の場合は開始日時以降ずっと送信対象です。
        </span>
      </div>

      <div id="line-message-settings-list">
        <%= f.fields_for :event_line_message_settings do |setting_fields| %>
          <%= render "line_message_setting_fields", f: setting_fields %>
        <% end %>
      </div>

      <div class="admin-form-group">
        <button type="button" id="add-line-message-setting" class="btn btn-gray" style="padding: 8px 16px;">
          ＋ 設定を追加
        </button>
      </div>
    </div>

      <div class="admin-form-actions">
        <%= link_to "キャンセル", admin_event_path(@event), class: "btn btn-gray" %>
        <%= f.submit "保存", class: "btn btn-tarco" %>
      </div>

      <template id="line-message-setting-template">
        <%= f.fields_for :event_line_message_settings, EventLineMessageSetting.new(enabled: true), child_index: "NEW_RECORD" do |setting_fields| %>
          <%= render "line_message_setting_fields", f: setting_fields %>
        <% end %>
      </template>
    <% end %>
  </div>

  <div class="admin-form-section admin-line-message-panel" data-line-message-panel="broadcast" <%= "hidden" unless active_line_message_tab == "broadcast" %>>
    <div class="admin-form-section-title">参加登録済みユーザーへの一括配信</div>

    <div class="admin-form-group">
      <span class="admin-form-help" style="font-size: 11px;">
        既にこのイベントへ参加登録しているLINEユーザーを対象に、即時配信または日時指定の予約配信を行います。
        配信前の一括配信は編集・取消できます。
      </span>
    </div>

    <% if @editing_event_line_message_broadcast %>
      <div class="admin-form-section-title" style="font-size:15px;margin-top:20px;">一括配信を編集</div>
      <%= render "line_message_broadcast_form",
                 broadcast: @editing_event_line_message_broadcast,
                 form_url: line_message_broadcast_admin_event_path(@event, @editing_event_line_message_broadcast),
                 form_method: :patch,
                 submit_label: "一括配信を更新" %>
    <% else %>
      <div class="admin-form-section-title" style="font-size:15px;margin-top:20px;">新規一括配信</div>
      <%= render "line_message_broadcast_form",
                 broadcast: @event_line_message_broadcast,
                 form_url: line_message_broadcasts_admin_event_path(@event),
                 form_method: :post,
                 submit_label: "一括配信を作成" %>
    <% end %>

    <div class="admin-form-section-title" style="font-size:15px;margin-top:28px;">一括配信リスト</div>
    <% if @event_line_message_broadcasts.any? %>
      <div class="admin-participant-table-wrap">
        <table class="admin-participant-table">
          <thead>
            <tr>
              <th>ステータス</th>
              <th>配信予定日時</th>
              <th>配信完了日時</th>
              <th>配信数</th>
              <th>メッセージ</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @event_line_message_broadcasts.each do |broadcast| %>
              <tr>
                <td>
                  <% badge_class =
                    if broadcast.status_delivered?
                      "admin-badge-success"
                    elsif broadcast.status_cancelled?
                      "admin-badge-secondary"
                    elsif broadcast.status_delivering?
                      "admin-badge-info"
                    else
                      "admin-badge-warning"
                    end
                  %>
                  <span class="admin-badge <%= badge_class %>"><%= broadcast.status_label %></span>
                </td>
                <td><%= l(broadcast.scheduled_at, format: :short) %></td>
                <td><%= broadcast.sent_at ? l(broadcast.sent_at, format: :short) : "-" %></td>
                <td>
                  <% if broadcast.status_delivered? || broadcast.status_delivering? %>
                    <%= broadcast.delivered_count %>名
                    <% if broadcast.failed_count.positive? %>
                      <span class="admin-form-help">（失敗 <%= broadcast.failed_count %>名）</span>
                    <% end %>
                  <% else %>
                    配信前
                  <% end %>
                </td>
                <td style="max-width:360px;"><%= simple_format(broadcast.message) %></td>
                <td>
                  <% if broadcast.editable? %>
                    <%= link_to "編集", edit_line_message_broadcast_admin_event_path(@event, broadcast), class: "btn btn-gray", style: "padding:6px 10px;font-size:12px;" %>
                    <%= link_to "取消", line_message_broadcast_admin_event_path(@event, broadcast), method: :delete, data: { confirm: "この一括配信を取り消しますか？" }, class: "btn btn-danger", style: "padding:6px 10px;font-size:12px;" %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div style="padding: 20px 16px; text-align: center; color: #8f8f8f;">
        一括配信はまだありません
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var tabs = document.querySelectorAll("[data-line-message-tab]");
    var panels = document.querySelectorAll("[data-line-message-panel]");

    function activateTab(tabName) {
      tabs.forEach(function(tab) {
        var active = tab.dataset.lineMessageTab === tabName;
        tab.classList.toggle("is-active", active);
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });

      panels.forEach(function(panel) {
        panel.hidden = panel.dataset.lineMessagePanel !== tabName;
      });
    }

    tabs.forEach(function(tab) {
      tab.addEventListener("click", function() {
        activateTab(tab.dataset.lineMessageTab);
      });
    });

    var list = document.getElementById("line-message-settings-list");
    var addButton = document.getElementById("add-line-message-setting");
    var template = document.getElementById("line-message-setting-template");

    if (list && addButton && template) {
      function updatePositions() {
        list.querySelectorAll(".js-line-message-setting:not([style*='display: none'])").forEach(function(row, index) {
          var positionInput = row.querySelector(".js-line-message-position");
          if (positionInput) positionInput.value = index;
        });
      }

      addButton.addEventListener("click", function() {
        var key = new Date().getTime();
        list.insertAdjacentHTML("beforeend", template.innerHTML.replace(/NEW_RECORD/g, key));
        updatePositions();
      });

      list.addEventListener("click", function(event) {
        var button = event.target.closest(".js-remove-line-message-setting");
        if (!button) return;

        var row = button.closest(".js-line-message-setting");
        var destroyInput = row.querySelector(".js-line-message-destroy");
        if (destroyInput) {
          destroyInput.value = "1";
          row.style.display = "none";
        } else {
          row.remove();
        }
        updatePositions();
      });

      updatePositions();
    }

    document.querySelectorAll(".js-line-message-broadcast-form").forEach(function(form) {
      var scheduledAtField = form.querySelector(".js-scheduled-at-field");
      var scheduledAtInput = form.querySelector(".js-scheduled-at-input");
      var deliveryTypeInputs = form.querySelectorAll(".js-delivery-type");
      if (!scheduledAtField || !scheduledAtInput || deliveryTypeInputs.length === 0) return;

      function updateScheduledAtInput() {
        var immediateInput = form.querySelector(".js-delivery-type[value='immediate']");
        var immediate = immediateInput && immediateInput.checked;
        scheduledAtInput.disabled = immediate;
        scheduledAtField.classList.toggle("is-disabled", immediate);
      }

      deliveryTypeInputs.forEach(function(input) {
        input.addEventListener("change", updateScheduledAtInput);
      });

      updateScheduledAtInput();
    });
  });
</script>
