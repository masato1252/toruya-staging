<div class="message centerize">
  <h3 class="desc break-line-content"><%= t("line_verification.line_login_confirm_title") %></h3>
  <p class="desc">
  <%= t("line_verification.line_login_confirm_desc_html") %>
  </p>

  <% login_url = line_login_url(current_user.social_account, request.url, who: MessageEncryptor.encrypt(CallbacksController::SHOP_OWNER_CUSTOMER_SELF)) %>
  <% if login_url.present? %>
    <a href="<%= login_url %>" class="btn line-button with-wording with-logo" data-method="post">
      <%= image_pack_tag "media/assets/booking/btn_login_base.png" %>
      <%= I18n.t("common.line_login_btn_word") %>
    </a>
  <% else %>
    <p class="desc" style="color: red;">
      LINE Login API の設定が完了していません。<br>
      設定画面に戻り、Login API の情報を入力してください。
    </p>
  <% end %>
</div>
