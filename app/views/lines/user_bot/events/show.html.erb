<div class="container-fluid">
  <div class="row">
    <div class="col-sm-6 px-0 settings-view">
      <div class="form with-top-bar">
        <%= render "lines/user_bot/top_navigation_bar",
          title: @event.title,
          back_path: lines_user_bot_events_path(business_owner_id: business_owner_id) %>

        <div class="field-header">
          <%= @event.title %>
          <span class="badge <%= @event.published? ? 'badge-success' : 'badge-secondary' %>">
            <%= @event.published? ? "公開中" : "非公開" %>
          </span>
        </div>

        <div class="field-row">
          <div class="text-sm text-gray-600">
            <% if @event.start_at %>
              開催期間: <%= l(@event.start_at, format: :long) %> 〜 <%= @event.end_at ? l(@event.end_at, format: :long) : "未設定" %>
            <% end %>
            <br>
            公開URL: <code>/<%= @event.slug %></code>
          </div>
        </div>

        <div class="field-header">コンテンツ一覧</div>
        <div class="booking-pages-list">
          <% @event_contents.each do |content| %>
            <%= content_tag :div, class: "field-row with-next-arrow" do %>
              <%= link_to lines_user_bot_event_content_path(content, business_owner_id: business_owner_id) do %>
                <div class="flex justify-between w-full">
                  <div>
                    <h3 class="underline text-gray-700"><%= content.title %></h3>
                    <div class="desc text-sm">
                      <%= content.seminar_content_type? ? "セミナー講演" : "展示ブース" %>
                      <% if content.capacity %>
                        | 上限: <%= content.capacity %>人 (利用済: <%= content.usage_count %>人)
                      <% end %>
                    </div>
                  </div>
                  <i class="fa fa-angle-right"></i>
                </div>
              <% end %>
            <% end %>
          <% end %>

          <% if @event_contents.empty? %>
            <div class="field-row centerize text-gray-500">
              <p>コンテンツはまだありません</p>
            </div>
          <% end %>
        </div>

        <%= render "lines/user_bot/bottom_navigation_bar", klass: "space-around" do %>
          <%= link_to edit_lines_user_bot_event_path(@event, business_owner_id: business_owner_id), class: "btn btn-tarco btn-circle btn-with-word" do %>
            <i class="fas fa-edit fa-2x"></i>
            <div class="word">編集</div>
          <% end %>
          <%= link_to new_lines_user_bot_event_event_content_path(@event, business_owner_id: business_owner_id), class: "btn btn-yellow btn-circle btn-save btn-tweak btn-with-word" do %>
            <i class="fas fa-plus fa-2x"></i>
            <div class="word">コンテンツ追加</div>
          <% end %>
          <%= link_to analytics_lines_user_bot_event_path(@event, business_owner_id: business_owner_id), class: "btn btn-info btn-circle btn-with-word" do %>
            <i class="fas fa-chart-bar fa-2x"></i>
            <div class="word">解析</div>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="col-sm-6 px-0 hidden-xs preview-view"></div>
  </div>
</div>
